# claude-switch TUI 데모 녹화 (데모 모드 — 실계정 정보 없음)
# 사용법: PATH="$PWD/bin:$PATH" vhs demo.tape
Output docs/demo.gif

Set FontSize 16
Set Width 900
Set Height 340
Set Padding 24
Set Theme "Catppuccin Mocha"
Set TypingSpeed 60ms

Env CLAUDE_SWITCH_DEMO "1"

Type "claude-switch"
Sleep 500ms
Enter
Sleep 2s
Enter
Sleep 2.2s
Down
Sleep 800ms
Enter
Sleep 1.8s
Type "q"
Sleep 500ms
